rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isBootstrapAdmin() {
      return request.auth.token.email.lower() == "henrythonny@gmail.com".lower();
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().uid == userId &&
                      incoming().role == (isBootstrapAdmin() ? "admin" : "user");
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Templates
    match /templates/{templateId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // History
    match /history/{historyId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(incoming().userId) && 
                      isValidId(historyId) &&
                      incoming().url is string && 
                      incoming().prompt is string && 
                      incoming().timestamp is timestamp;
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId);
    }

    // Profiles
    match /profiles/{userId} {
      allow read, write: if isOwner(userId) && isValidId(userId);
    }
  }
}
